    <flow id="truck_C10_AR" type="truck" route="R_C10_AR"
          begin="0"   end="3600" number="22"  departSpeed="0" departLane="best"/>
    <flow id="truck_C06_FD" type="truck" route="R_C06_FD"
          begin="0"   end="2700" number="10"  departSpeed="0" departLane="best"/>
    <flow id="truck_C09"    type="truck" route="R_C09_BSF"
          begin="0"   end="2700" number="10"  departSpeed="0" departLane="best"/>

    <!-- ── MOTORCYCLES (12% → 120 vehicles) ── -->
    <flow id="moto_C01_NS"  type="motorcycle" route="R_C01_NS"
          begin="0"    end="7200" number="22"  departSpeed="max" departLane="best"/>
    <flow id="moto_C04_BJ"  type="motorcycle" route="R_C04_BJOM"
